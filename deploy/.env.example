# Not needed if you use ./setup.sh — it generates deploy/.env for you.
# For manual setup: copy this to .env and fill in the values before running
# docker compose up.

# Strong random string — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# PostgreSQL password — use something strong. Generate with:
#   openssl rand -hex 24
POSTGRES_PASSWORD=change_me_strong_password
